# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://percepta:percepta_dev@localhost:5432/percepta

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# Encryption (for Takealot API keys at rest)
ENCRYPTION_KEY=change-me-32-byte-hex-key-here!!

# Takealot API
TAKEALOT_API_BASE_URL=https://seller-api.takealot.com

# Webhook
WEBHOOK_PATH=/api/webhooks/takealot

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=alerts@percepta.co.za

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
