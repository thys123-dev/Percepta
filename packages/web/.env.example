# ── API URL ───────────────────────────────────────────────────────────────────────
# Full origin of the API server — used for Socket.io real-time connection.
# Defaults to http://localhost:3001 if not set (fine for local dev).
VITE_API_URL=http://localhost:3001

# ── Observability (optional) ─────────────────────────────────────────────────────
# Sentry: create a project at sentry.io and paste the DSN here
VITE_SENTRY_DSN=

# PostHog: create a project at posthog.com and paste the project API key here
VITE_POSTHOG_KEY=
